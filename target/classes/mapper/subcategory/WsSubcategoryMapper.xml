<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wineshop.subcategory.mapper.WsSubcategoryMapper">

    <resultMap id="BaseMap" type="com.wineshop.subcategory.entity.WsSubcategory">
        <id property="id" column="id"/>
        <result property="categoryId" column="category_id"/>
        <result property="name" column="name"/>
        <result property="sort" column="sort"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="BaseColumns">id, category_id, name, sort, status, created_at, updated_at</sql>

    <select id="selectAll" resultMap="BaseMap">
        select <include refid="BaseColumns"/>
        from ws_subcategory
        order by category_id asc, sort asc, id asc
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        insert into ws_subcategory(category_id, name, sort, status)
        values (#{categoryId}, #{name}, #{sort}, #{status})
    </insert>

    <update id="updateById">
        update ws_subcategory
        set category_id = #{categoryId},
            name = #{name},
            sort = #{sort},
            status = #{status}
        where id = #{id}
    </update>

    <delete id="deleteById">
        delete from ws_subcategory where id = #{id}
    </delete>

    <!-- TODO: add subcategory list SQL -->
</mapper>
