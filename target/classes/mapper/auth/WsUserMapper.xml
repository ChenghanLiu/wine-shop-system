<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wineshop.user.mapper.WsUserMapper">

    <resultMap id="BaseMap" type="com.wineshop.user.entity.WsUser">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="password" column="password"/>
        <result property="nickname" column="nickname"/>
        <result property="phone" column="phone"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="BaseColumns">id, username, password, nickname, phone, status, created_at, updated_at</sql>

    <select id="selectByUsername" resultMap="BaseMap">
        select <include refid="BaseColumns"/>
        from ws_user
        where username = #{username}
        limit 1
    </select>

    <select id="selectById" resultMap="BaseMap">
        select <include refid="BaseColumns"/>
        from ws_user
        where id = #{id}
        limit 1
    </select>

    <select id="selectAll" resultMap="BaseMap">
        select <include refid="BaseColumns"/>
        from ws_user
        order by id desc
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        insert into ws_user(username, password, nickname, phone, status)
        values (#{username}, #{password}, #{nickname}, #{phone}, #{status})
    </insert>

    <update id="updateProfileById">
        update ws_user
        set nickname = #{nickname},
            phone = #{phone}
        where id = #{id}
    </update>

    <update id="updateByAdmin">
        update ws_user
        set nickname = #{nickname},
            phone = #{phone},
            status = #{status}
        where id = #{id}
    </update>

    <delete id="deleteById">
        delete from ws_user where id = #{id}
    </delete>

</mapper>

