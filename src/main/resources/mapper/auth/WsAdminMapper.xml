<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wineshop.admin.mapper.WsAdminMapper">

    <resultMap id="BaseMap" type="com.wineshop.admin.entity.WsAdmin">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="password" column="password"/>
        <result property="realName" column="real_name"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="BaseColumns">id, username, password, real_name, status, created_at, updated_at</sql>

    <select id="selectByUsername" resultMap="BaseMap">
        select <include refid="BaseColumns"/>
        from ws_admin
        where username = #{username}
        limit 1
    </select>

    <select id="selectByUsernameAndPassword" resultMap="BaseMap">
        select <include refid="BaseColumns"/>
        from ws_admin
        where username = #{username}
        and password = #{password}
        and status = 1
        limit 1
    </select>

    <select id="selectById" resultMap="BaseMap">
        select <include refid="BaseColumns"/>
        from ws_admin
        where id = #{id}
        limit 1
    </select>

    <update id="updatePasswordById">
        update ws_admin
        set password = #{password}
        where id = #{id}
    </update>

</mapper>

